meta {
  name: 8090_shots
  type: http
  seq: 1
}

post {
  url: http://localhost:8090/storage/shots
  body: json
  auth: inherit
}

body:json {
  {
    "arena_id": "rogers_arena",
    "batch_timestamp": "2025-01-01T00:00:00Z",
    "batch_count": 1,
    "shots": [
      {
        "game_id": 1,
        "period": 1,
        "shot_type": "wrist",
        "game_time_seconds": 10,
        "shots_last_5_minutes": 2
      }
    ]
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
